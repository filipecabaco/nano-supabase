{
  "name": "nano-supabase",
  "version": "0.1.0",
  "description": "A lightweight Supabase-compatible client for PGlite - runs PostgreSQL entirely in the browser/edge",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "nano-supabase": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node scripts/build.js && pnpm run build:types",
    "build:types": "tsc --emitDeclarationOnly",
    "build:dev": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build",
    "test": "vitest run tests/",
    "test:auth": "vitest run tests/auth-integration.test.ts",
    "test:data": "vitest run tests/integration.test.ts tests/supabase-client.test.ts",
    "test:storage": "vitest run tests/storage.test.ts",
    "test:fetch": "vitest run tests/fetch-adapter.test.ts",
    "test:apps": "vitest run tests/applications.test.ts tests/full-user-flow.test.ts",
    "test:perf": "vitest run tests/performance.test.ts",
    "test:cli": "vitest run tests/cli.test.ts",
    "example:basic": "tsx examples/basic.ts",
    "example:server": "tsx examples/tcp-server.ts",
    "example:prisma": "tsx examples/prisma-tcp.ts",
    "prisma:generate": "prisma generate --schema=examples/prisma/schema.prisma",
    "cli": "node dist/cli.js"
  },
  "keywords": [
    "pglite",
    "postgresql",
    "supabase",
    "postgrest",
    "edge",
    "webcontainer",
    "deno",
    "bun",
    "cloudflare-workers"
  ],
  "author": "filipecabaco",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/filipecabaco/nano-supabase.git"
  },
  "homepage": "https://github.com/filipecabaco/nano-supabase#readme",
  "bugs": {
    "url": "https://github.com/filipecabaco/nano-supabase/issues"
  },
  "devDependencies": {
    "@electric-sql/pglite": "0.4.0",
    "@electric-sql/pglite-socket": "^0.0.22",
    "@prisma/client": "^6.19.2",
    "@types/node": "^25.1.0",
    "esbuild": "^0.27.3",
    "prisma": "^6.19.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "@electric-sql/pglite": ">=0.4.0"
  },
  "peerDependenciesMeta": {
    "@electric-sql/pglite": {
      "optional": true
    }
  },
  "dependencies": {
    "@electric-sql/pglite-tools": "^0.3.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@supabase/mcp-server-supabase": "^0.7.0",
    "@supabase/supabase-js": "^2.99.2",
    "@types/pg": "^8.18.0",
    "pg": "^8.20.0",
    "postgrest-parser": "^0.1.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  }
}
